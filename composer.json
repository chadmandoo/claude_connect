{
    "name": "claude-connect/server",
    "description": "Web-first project-based agent system orchestrating Claude CLI tasks",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "ext-swoole": ">=6.0",
        "ext-pdo_pgsql": "*",
        "ext-redis": "*",
        "ext-json": "*",
        "hyperf/database": "^3.1",
        "hyperf/db-connection": "^3.1",
        "hyperf/config": "^3.1",
        "hyperf/command": "^3.1",
        "hyperf/di": "^3.1",
        "hyperf/framework": "^3.1",
        "hyperf/guzzle": "^3.1",
        "hyperf/http-server": "^3.1",
        "hyperf/logger": "^3.1",
        "hyperf/redis": "^3.1",
        "nyholm/psr7": "^1.8",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "scripts": {
        "start": "php bin/hyperf.php start",
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text --coverage-html runtime/coverage"
    }
}
