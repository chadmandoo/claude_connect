APP_NAME=claude-connect
APP_ENV=production

# Server
SERVER_PORT=9501
WORKER_NUM=4

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_DB=0

# Claude CLI
CLAUDE_CLI_PATH=/Users/chadpeppers/.local/bin/claude
CLAUDE_MAX_TURNS=25
CLAUDE_MAX_BUDGET_USD=5.00
CLAUDE_DEFAULT_MODEL=
# Comma-separated tools allowed in non-interactive mode (empty = tools auto-denied)
CLAUDE_ALLOWED_TOOLS=Bash,Read,Write,Edit,Glob,Grep,WebSearch,WebFetch

# Voyage AI Embeddings
VOYAGE_API_KEY=

# Web Frontend
WEB_AUTH_PASSWORD=
WEB_USER_ID=web_user
