[Unit]
Description=Claude Connect Task Worker
After=network.target docker.service claude-connect.service
Wants=docker.service

[Service]
Type=simple
User=chadpeppers
Group=staff
WorkingDirectory=/Users/chadpeppers/Projects/claude_connect
ExecStart=/opt/homebrew/bin/php bin/task-worker.php
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal
EnvironmentFile=/Users/chadpeppers/Projects/claude_connect/.env

[Install]
WantedBy=multi-user.target
